{
  "name": "iroguide-frontend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:rules": "firebase emulators:exec --project demo-iroguide-rules --only firestore,storage \"vitest run --config vitest.rules.config.ts\"",
    "dast:prelaunch": "node scripts/prelaunch-dast.mjs",
    "smoke:security": "node scripts/prelaunch-dast.mjs",
    "check": "npm run typecheck && npm run lint && npm test && npm run test:rules && npm run build",
    "smoke:production": "node scripts/production-smoke.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@opentelemetry/api": "^1.9.1",
    "boneyard-js": "^1.8.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "firebase-tools": "^15.22.2",
    "typescript": "6.0.3",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "@opentelemetry/core": "2.8.0",
    "postcss": "8.5.15",
    "uuid": "14.0.1"
  }
}
