rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsReview(reviewId) {
      return signedIn()
        && get(/databases/$(database)/documents/reviews/$(reviewId)).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if ownsExistingDocument();
      allow write: if false;

      match /messages/{messageId} {
        allow read: if ownsReview(reviewId);
        allow write: if false;
      }
    }

    match /uploads/{uploadId} {
      allow read: if ownsExistingDocument();
      allow write: if false;
    }
  }
}
