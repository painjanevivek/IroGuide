rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function isPublicCommunityPost() {
      return resource.data.visibility == "public";
    }

    function ownsReview(reviewId) {
      return signedIn()
        && get(/databases/$(database)/documents/reviews/$(reviewId)).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();

      match /messages/{messageId} {
        allow read: if ownsReview(reviewId);
        allow write: if false;
      }
    }

    match /reviewDrafts/{draftId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }

    match /communityPosts/{postId} {
      allow read: if signedIn() && isPublicCommunityPost();
      allow create, update, delete: if false;

      match /comments/{commentId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/communityPosts/$(postId)).data.visibility == "public";
        allow write: if false;
      }

      match /interactions/{userId} {
        allow read: if signedIn()
          && userId == request.auth.uid
          && get(/databases/$(database)/documents/communityPosts/$(postId)).data.visibility == "public";
        allow write: if false;
      }
    }

    match /uploads/{uploadId} {
      allow read: if ownsExistingDocument();
      allow write: if false;
    }
  }
}
