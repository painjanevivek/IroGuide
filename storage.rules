rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserPath(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/reviews/{reviewId}/source.png {
      allow read: if ownsUserPath(userId);
      allow write: if false;
    }

    match /users/{userId}/reviews/{reviewId}/source.jpg {
      allow read: if ownsUserPath(userId);
      allow write: if false;
    }

    match /users/{userId}/reviews/{reviewId}/source.webp {
      allow read: if ownsUserPath(userId);
      allow write: if false;
    }
  }
}
