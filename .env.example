NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional privacy-aware product analytics.
# Page views and user events load only after the user accepts site data.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Server-side account storage and token verification.
# Use FIREBASE_ADMIN_SERVICE_ACCOUNT_BASE64, FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON,
# or the three split values below.
FIREBASE_ADMIN_SERVICE_ACCOUNT_BASE64=
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_STORAGE_BUCKET=

# Optional private admin tools.
# Comma-separate verified Firebase auth emails or UIDs that can view /admin/bug-reports.
IROGUIDE_ADMIN_EMAILS=
IROGUIDE_ADMIN_UIDS=

# Review provider. Local development can use explicit demo mode.
# Production fails closed unless a live provider is configured.
IROGUIDE_REVIEW_PROVIDER=auto
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.5-vl
OPENROUTER_FALLBACK_MODEL=
OPENROUTER_SITE_URL=https://iroguide.com
OPENROUTER_APP_NAME=IroGuide

# Optional developer notification email for contact bug reports.
# Bug reports are stored in Firestore even when email delivery is not configured.
RESEND_API_KEY=
BUG_REPORT_TO_EMAIL=
BUG_REPORT_FROM_EMAIL=
